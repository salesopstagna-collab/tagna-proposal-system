# === BANCO DE DADOS ===
# Cole aqui a DATABASE_URL gerada pelo servico PostgreSQL do Railway
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# === AUTENTICACAO ===
# Gere uma string aleatoria segura (ex: openssl rand -hex 32)
JWT_SECRET="sua-chave-secreta-muito-longa-aqui"
JWT_REFRESH_SECRET="outra-chave-secreta-para-refresh-token"

# === SERVIDOR ===
NODE_ENV="production"
PORT=3001

# === FRONTEND ===
# URL do servico frontend no Railway (gerada apos o deploy do frontend)
FRONTEND_URL="https://seu-frontend.railway.app"

# === HUBSPOT (opcional) ===
HUBSPOT_ACCESS_TOKEN=""
